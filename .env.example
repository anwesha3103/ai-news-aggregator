# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# The `.env` file is listed in .gitignore and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Get your free API key from https://newsapi.org/register
NEWS_API_KEY=3fd3e35cc4e143c18679b72bea2fdc1b

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:anwesha@localhost:5432/news_aggregator

# Optional: swap to "t5-base" for better summaries (slower on CPU)
SUMMARIZATION_MODEL=t5-small
